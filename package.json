{
  "name": "react-native-opaque",
  "version": "1.0.0",
  "description": "React Native JSI binding for the OPAQUE password-authenticated key exchange protocol",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "rust/target/aarch64-apple-ios/release/libopaque_rust.a",
    "rust/target/aarch64-apple-ios-sim/release/libopaque_rust.a",
    "rust/target/x86_64-apple-ios/release/libopaque_rust.a",
    "rust/target/aarch64-linux-android/release/libopaque_rust.a",
    "rust/target/arm-linux-androideabi/release/libopaque_rust.a",
    "rust/target/i686-linux-android/release/libopaque_rust.a",
    "rust/target/x86_64-linux-android/release/libopaque_rust.a",
    "*.podspec",
    "Makefile",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepack": "bob build",
    "release": "release-it",
    "bootstrap": "yarn install && yarn install --cwd example && yarn --cwd example pods",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "opaque",
    "pake",
    "authentication",
    "crypto"
  ],
  "repository": "https://github.com/serenity-kit/react-native-opaque",
  "author": "Nik Graf <nik@nikgraf.com> (https://github.com/nikgraf)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/serenity-kit/react-native-opaque/issues"
  },
  "homepage": "https://github.com/serenity-kit/react-native-opaque#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.0.0",
    "@evilmartians/lefthook": "^2.1.0",
    "@playwright/test": "^1.58.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@release-it/conventional-changelog": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "commitlint": "^20.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-ft-flow": "^3.0.0",
    "eslint-plugin-prettier": "^5.5.0",
    "jest": "^30.0.0",
    "pod-install": "^1.0.0",
    "prettier": "^3.8.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "^0.40.0",
    "release-it": "^19.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.73.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@serenity-kit/opaque": "^1.1.0"
  },
  "jest": {
    "preset": "react-native",
    "passWithNoTests": true,
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native-community",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "example/",
    "scripts/",
    "babel.config.js"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
